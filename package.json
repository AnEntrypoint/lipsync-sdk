{
  "name": "lipsync-sdk",
  "version": "1.1.0",
  "type": "module",
  "description": "Fast text-driven lipsync codec — Oculus viseme word→blendshape conversion (TalkingHead-derived) plus ARKit mapping and AFAN binary streaming for downstream tools",
  "main": "lipsync-sdk-node.mjs",
  "browser": "lipsync-sdk-browser.js",
  "exports": {
    ".": {
      "browser": "./lipsync-sdk-browser.js",
      "default": "./lipsync-sdk-node.mjs"
    },
    "./core": "./lipsync-core.mjs",
    "./floosie": "./lipsync-floosie.mjs"
  },
  "files": [
    "lipsync-core.mjs",
    "lipsync-sdk-browser.js",
    "lipsync-sdk-node.mjs",
    "lipsync-floosie.mjs",
    "modules/",
    "NOTICE"
  ],
  "keywords": [
    "lipsync",
    "blendshape",
    "arkit",
    "avatar",
    "tts",
    "viseme",
    "oculus",
    "talkinghead",
    "afan"
  ],
  "license": "MIT"
}