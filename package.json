{
  "name": "lipsync-sdk",
  "version": "1.3.6",
  "type": "module",
  "description": "Fast text-driven lipsync codec — Oculus viseme word→blendshape conversion (TalkingHead-derived) plus ARKit mapping and AFAN binary streaming for downstream tools",
  "main": "lipsync-sdk-node.mjs",
  "browser": "lipsync-sdk-browser.js",
  "exports": {
    ".": {
      "browser": "./lipsync-sdk-browser.js",
      "default": "./lipsync-sdk-node.mjs"
    },
    "./core": "./lipsync-core.mjs",
    "./floosie": "./lipsync-floosie.mjs",
    "./afan": "./lipsync-afan.mjs",
    "./vrm": "./lipsync-vrm.mjs"
  },
  "files": [
    "lipsync-core.mjs",
    "lipsync-sdk-browser.js",
    "lipsync-sdk-node.mjs",
    "lipsync-floosie.mjs",
    "lipsync-afan.mjs",
    "lipsync-vrm.mjs",
    "modules/",
    "NOTICE"
  ],
  "keywords": [
    "lipsync",
    "blendshape",
    "arkit",
    "avatar",
    "tts",
    "viseme",
    "oculus",
    "talkinghead",
    "afan",
    "vrm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AnEntrypoint/lipsync-sdk.git"
  },
  "license": "MIT"
}
